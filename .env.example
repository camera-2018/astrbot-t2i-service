PORT=8999

# 图片生命时间（小时），默认24小时
# 超过这个时间的图片文件将被自动清理
IMAGE_LIFETIME_HOURS=24

# 速率限制，0 表示关闭
RATE_LIMIT_MAX_REQUESTS=0
RATE_LIMIT_WINDOW_SECONDS=0

# 默认截图参数
# DEFAULT_IMAGE_TYPE 可选 png / jpeg；DEFAULT_IMAGE_QUALITY 仅在最终输出为 jpeg 时生效
DEFAULT_IMAGE_TYPE=png
DEFAULT_IMAGE_QUALITY=
DEFAULT_DEVICE_SCALE_FACTOR_LEVEL=normal
